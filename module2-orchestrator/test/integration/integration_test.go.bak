package integration

import (
	"context"
	"fmt"
	"testing"
	"time"

	corev1 "k8s.io/api/core/v1"
	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
	"sigs.k8s.io/controller-runtime/pkg/client"
	"sigs.k8s.io/controller-runtime/pkg/envtest"

	tasksv1 "github.com/orchestrator/module2-orchestrator/api/v1"
	"github.com/orchestrator/module2-orchestrator/controllers"
	"github.com/sirupsen/logrus"
	"github.com/stretchr/testify/require"
	ctrl "sigs.k8s.io/controller-runtime"
)

// TestEnv represents an integration test environment
type TestEnv struct {
	client client.Client
	env    *envtest.Environment
	cancel context.CancelFunc
}

// SetupTestEnvironment creates a test Kubernetes environment using envtest
func SetupTestEnvironment(t *testing.T) *TestEnv {
	ctx, cancel := context.WithCancel(context.Background())

	testEnv := &envtest.Environment{}

	config, err := testEnv.Start()
	require.NoError(t, err)
	require.NotNil(t, config)

	scheme := testEnv.Scheme
	require.NoError(t, tasksv1.AddToScheme(scheme))

	cl, err := client.New(config, client.Options{Scheme: scheme})
	require.NoError(t, err)

	// Start the manager
	mgr, err := ctrl.NewManager(config, ctrl.Options{
		Scheme: scheme,
	})
	require.NoError(t, err)

	reconciler := &controllers.CloudTaskReconciler{
		Client: mgr.GetClient(),
		Scheme: mgr.GetScheme(),
		Log:    logrus.New(),
	}

	err = reconciler.SetupWithManager(mgr)
	require.NoError(t, err)

	go func() {
		err := mgr.Start(ctx)
		if err != nil {
			t.Logf("Manager exited with error: %v", err)
		}
	}()

	return &TestEnv{
		client: cl,
		env:    testEnv,
		cancel: cancel,
	}
}

// Cleanup cleans up the test environment
func (te *TestEnv) Cleanup(t *testing.T) {
	te.cancel()
	if te.env != nil {
		err := te.env.Stop()
		if err != nil {
			t.Logf("Failed to stop test environment: %v", err)
		}
	}
}

// TestCloudTaskCreation tests creating a CloudTask and verifying it's stored
func TestCloudTaskCreation(t *testing.T) {
	t.Skip("Requires envtest to be properly configured")

	testEnv := SetupTestEnvironment(t)
	defer testEnv.Cleanup(t)

	ctx := context.Background()

	// Create a CloudTask
	ct := &tasksv1.CloudTask{
		ObjectMeta: metav1.ObjectMeta{
			Name:      "test-task",
			Namespace: "default",
		},
		Spec: tasksv1.CloudTaskSpec{
			Image:    "alpine:latest",
			TenantID: "test-tenant",
			Retries:  3,
			Priority: 50,
		},
	}

	err := testEnv.client.Create(ctx, ct)
	require.NoError(t, err)

	// Retrieve the CloudTask
	retrieved := &tasksv1.CloudTask{}
	err = testEnv.client.Get(ctx, client.ObjectKeyFromObject(ct), retrieved)
	require.NoError(t, err)

	require.Equal(t, ct.Name, retrieved.Name)
	require.Equal(t, ct.Spec.Image, retrieved.Spec.Image)
	require.Equal(t, ct.Spec.TenantID, retrieved.Spec.TenantID)
}

// TestCloudTaskPodLifecycle tests the full lifecycle of a CloudTask and its Pod
func TestCloudTaskPodLifecycle(t *testing.T) {
	t.Skip("Requires envtest to be properly configured with Pod simulation")

	testEnv := SetupTestEnvironment(t)
	defer testEnv.Cleanup(t)

	ctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)
	defer cancel()

	// Create a CloudTask
	ct := &tasksv1.CloudTask{
		ObjectMeta: metav1.ObjectMeta{
			Name:      "test-task-lifecycle",
			Namespace: "default",
		},
		Spec: tasksv1.CloudTaskSpec{
			Image:    "alpine:latest",
			Command:  []string{"/bin/sh", "-c"},
			Args:     []string{"echo hello"},
			TenantID: "test-tenant",
			Retries:  1,
			Priority: 50,
		},
	}

	err := testEnv.client.Create(ctx, ct)
	require.NoError(t, err)

	// Wait for Pod to be created
	var pod *corev1.Pod
	for i := 0; i < 10; i++ {
		pod = &corev1.Pod{}
		err := testEnv.client.Get(ctx, client.ObjectKey{Name: "test-task-lifecycle-pod", Namespace: "default"}, pod)
		if err == nil {
			break
		}
		time.Sleep(500 * time.Millisecond)
	}

	require.NotNil(t, pod)

	// Update CloudTask status
	ct.Status.Phase = tasksv1.PhaseRunning
	ct.Status.PodName = pod.Name
	err = testEnv.client.Status().Update(ctx, ct)
	require.NoError(t, err)

	// Verify status was updated
	retrieved := &tasksv1.CloudTask{}
	err = testEnv.client.Get(ctx, client.ObjectKeyFromObject(ct), retrieved)
	require.NoError(t, err)
	require.Equal(t, tasksv1.PhaseRunning, retrieved.Status.Phase)
}

// BenchmarkCloudTaskReconciliation benchmarks the reconciliation loop
func BenchmarkCloudTaskReconciliation(b *testing.B) {
	log := utils.InitializeLogger("warn")

	for i := 0; i < b.N; i++ {
		ct := &tasksv1.CloudTask{
			ObjectMeta: metav1.ObjectMeta{
				Name:      fmt.Sprintf("bench-task-%d", i),
				Namespace: "default",
			},
			Spec: tasksv1.CloudTaskSpec{
				Image:    "nginx:latest",
				TenantID: "tenant-1",
				Retries:  3,
				Priority: 50,
			},
		}

		reconciler := &controllers.CloudTaskReconciler{
			Log: log,
		}

		pod := reconciler.constructPod(ct)
		require.NotNil(b, pod)
	}
}
